// =========================================
// ÉDUQUER VOS CŒURS — Règles de sécurité Storage
// À coller dans Firebase Console > Storage > Règles > Publier
// =========================================
// Les fichiers de la Médiathèque sont lisibles par tout membre connecté ;
// chaque membre ne peut déposer que dans son propre dossier.

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /documents/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
